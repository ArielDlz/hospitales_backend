# SMTP - configuración de correo
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
PRIMER_ACCESO_DOMAIN=
PRIMER_ACCESO_PLACEHOLDER=pendiente