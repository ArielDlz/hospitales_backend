DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=hospitales_psicometricas
NODE_ENV=development
PORT=3000

# CORS - dominios permitidos (comma-separated, soporta *.dominio.com)
CORS_ORIGINS=*.arieldelao.dev,*.psiqueycultura.com

# JWT - clave secreta min 32 caracteres
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Brevo - correo transaccional (API)
BREVO_API_KEY=
MAIL_FROM=registro@arieldelao.dev
MAIL_FROM_NAME=Registro
ADMIN_NOTIFY_EMAIL=
PRIMER_ACCESO_DOMAIN=arieldelao.dev
PRIMER_ACCESO_PLACEHOLDER=pendiente
ADMIN_LOGIN_DOMAIN=admin.arieldelao.dev

# AWS S3 - almacenamiento de archivos de aspirantes
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=hospitales-assets
S3_PUBLIC_BASE_URL=https://hospitales-assets.s3.us-east-2.amazonaws.com

# Stripe - pagos de aspirantes (precio desde catálogo Stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=price_1Tr8J4FByYNF9ILkI3Wv6a4i
# 3D Secure en PaymentIntent: any | challenge (default challenge, alineado con Payment Element)
STRIPE_REQUEST_THREE_D_SECURE=challenge
# País ISO para defaultValues.billingDetails.address.country en el frontend
STRIPE_BILLING_COUNTRY=MX
