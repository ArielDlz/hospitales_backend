DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=hospitales_psicometricas
NODE_ENV=development
PORT=3000

# CORS - dominios permitidos (comma-separated, soporta *.dominio.com)
CORS_ORIGINS=*.arieldelao.dev,*.psiqueycultura.com

# JWT - clave secreta min 32 caracteres
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Brevo - correo transaccional (API)
BREVO_API_KEY=
MAIL_FROM=registro@arieldelao.dev
MAIL_FROM_NAME=Registro
ADMIN_NOTIFY_EMAIL=
PRIMER_ACCESO_DOMAIN=arieldelao.dev
PRIMER_ACCESO_PLACEHOLDER=pendiente
ADMIN_LOGIN_DOMAIN=admin.arieldelao.dev

# AWS S3 - almacenamiento de archivos de aspirantes
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=hospitales-assets
S3_PUBLIC_BASE_URL=https://hospitales-assets.s3.us-east-2.amazonaws.com
